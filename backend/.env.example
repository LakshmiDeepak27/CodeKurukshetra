PORT=3000
NODE_ENV=development

# Use a long random value in production. This invalidates sessions when changed.
AUTH_TOKEN_SECRET=replace-with-a-long-random-secret

# Google Cloud OAuth 2.0 Web application client ID. Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Comma-separated frontend origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=code_kurukshetra
DB_POOL_SIZE=10

# Optional judge override (defaults to ./judge or WSL on Windows)
# JUDGE_COMMAND=wsl.exe
# JUDGE_ARGS=bash -lc cd /mnt/e/Projects/CodeKurukshetra && ./judge
